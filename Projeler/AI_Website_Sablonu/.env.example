# AI Website Şablonu — Ortam Değişkenleri
# Bu dosyayi .env.local olarak kopyalayin ve degerleri doldurun.
# Hepsi opsiyoneldir; bos birakilirsa kod icindeki varsayilan deger kullanilir.

# Sitenizin tam adresi (SEO, sitemap.xml, Open Graph etiketleri icin)
NEXT_PUBLIC_SITE_URL=https://example.com

# Iletisim / CTA butonlarinda kullanilacak e-posta adresi
NEXT_PUBLIC_CONTACT_EMAIL=info@example.com

# Varsa topluluk linki (Skool, Discord, Circle vb.) — yoksa bos birakin
NEXT_PUBLIC_COMMUNITY_URL=

# Varsa egitim / kurs linki (Udemy, kendi platformunuz vb.) — yoksa bos birakin
NEXT_PUBLIC_TRAINING_URL=
