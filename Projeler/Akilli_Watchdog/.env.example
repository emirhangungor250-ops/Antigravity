# Akıllı Watchdog — Environment Variables
# Bu dosyayı .env olarak kopyala ve kendi değerlerinle doldur.

# ── Groq LLM (zorunlu) ───────────────────────────────
GROQ_API_KEY=<GROQ_API_KEY>
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_BASE_URL=https://api.groq.com/openai/v1

# ── Alarm e-postası ──────────────────────────────────
# Watchdog raporlarının gideceği adres.
ALERT_EMAIL=<ADMIN_EMAIL>

# Gmail API OAuth2 token (base64'lenmiş JSON) — Railway için.
GOOGLE_OUTREACH_TOKEN_JSON=
# Alternatif: Google Service Account JSON (production auth).
GOOGLE_SERVICE_ACCOUNT_JSON=

# ── Notion ───────────────────────────────────────────
NOTION_API_TOKEN=<NOTION_TOKEN>
# İkinci bir Notion workspace kullanıyorsan:
NOTION_SOCIAL_TOKEN=<NOTION_TOKEN>
# Varsayılan / örnek izlenen DB ID'leri:
NOTION_DATABASE_ID=<NOTION_DB_ID>
NOTION_DB_ORNEK=<NOTION_DB_ID>
# Operational log DB ID'si (opsiyonel — boşsa sadece console'a log basar):
NOTION_DB_OPS_LOG=

# ── Railway deployment probe ─────────────────────────
RAILWAY_TOKEN=<RAILWAY_TOKEN>
# İzlenen örnek projelerin Railway service ID'leri:
RAILWAY_SERVICE_ID_ORNEK=<RAILWAY_SERVICE_ID>
RAILWAY_SERVICE_ID_ORNEK_2=<RAILWAY_SERVICE_ID>

# ── Zamanlama ────────────────────────────────────────
CHECK_INTERVAL_HOURS=24
