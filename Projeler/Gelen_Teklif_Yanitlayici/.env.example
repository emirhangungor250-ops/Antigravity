# Gelen Teklif Yanıtlayıcı — environment
# Bu dosyayı `.env` olarak kopyalayıp doldur. Production'da (Railway vb.) aynı isimlerle
# servis env'ine geçir. Hiçbir gerçek sır bu dosyaya YAZILMAZ; .env push EDİLMEZ.

# ── Roller / kimlik ──────────────────────────────────────────────────────
# GÖNDEREN = otomasyonun adına çalıştığı içerik üreticisi/freelancer (markaya görünen).
# YÖNETİCİ = teklif/fiyat görüşmesini yürüten ekip üyesi (Partnerships Manager).
# Tek kişiysen GÖNDEREN ile YÖNETİCİ aynı isim/e-posta olabilir.
SENDER_NAME=<KULLANICI_ADI>           # ör. Ada Lovelace — markaya görünen ad + tanıştırma imzası
MANAGER_NAME=<EKIP_UYESI>             # ör. Maya — teklif imzası
# İngilizce teklifte gönderen için kullanılacak 3. tekil zamir: he / she / they
SENDER_PRONOUN=they
# Teklifteki "uyum" cümlesi: kitlen hangi alanla ilgili? (kendi nişine göre yaz)
AUDIENCE_PITCH=kitlesi yeni AI ve teknoloji araçlarıyla çok ilgili

# ── E-posta hesapları (Gmail) ────────────────────────────────────────────
# Gelen ilk temasın düşebileceği iki kutu (markalar genelde önce kişisele yazar).
SENDER_PRIMARY_EMAIL=<EMAIL>          # iş kutun, ör. you@yourdomain.com
SENDER_PERSONAL_EMAIL=<EMAIL>         # kişisel kutun, ör. you@gmail.com
MANAGER_EMAIL=<EMAIL>                 # teklif taslağı buraya, ör. manager@yourdomain.com
# "Bizim taraf" sayılan adresler (counterparty çıkarımında dış marka sayılmaz). Virgüllü.
# Boş bırakırsan yukarıdaki üç adres + domainleri kullanılır.
INTERNAL_ADDRESSES=

# ── Gmail OAuth token'ları ───────────────────────────────────────────────
# Her hesap için Google Cloud Console'dan OAuth client oluştur, gmail.modify + gmail.send
# scope'larıyla yetkilendir. Token JSON'unu ya oauth/<dosya>.json olarak kaydet ya da
# aşağıdaki env var'a tek satır JSON olarak koy (Railway için).
# Lokal dosya yolları: oauth/gmail-primary-token.json, oauth/gmail-manager-token.json,
#                      oauth/gmail-personal-token.json
GOOGLE_PRIMARY_TOKEN_JSON=
GOOGLE_MANAGER_TOKEN_JSON=
GOOGLE_PERSONAL_TOKEN_JSON=

# ── LLM (niteleme + yazım) ───────────────────────────────────────────────
# Varsayılan: gpt-4.1-mini @ OpenAI direkt. OpenAI hesabında "data sharing" açıksa mini tier
# günlük belli bir token'a kadar ücretsizdir (bedava krediden faydalanmak için OpenRouter
# DEĞİL OpenAI direkt çağrı şart). Anahtar: https://platform.openai.com/api-keys
OPENAI_API_KEY_DATA_SHARED=<OPENAI_API_KEY>
# Yedek (ücretli) OpenAI anahtarı — data-shared yoksa buna düşer.
OPENAI_API_KEY=<OPENAI_API_KEY>
# Opsiyonel: yalnız "/"-li bir model (ör. google/gemini-2.5-flash) verirsen gerekir.
OPENROUTER_API_KEY=<OPENROUTER_API_KEY>
# Model override (varsayılan üçü de gpt-4.1-mini; bare ad = OpenAI direkt)
QUALIFY_MODEL=gpt-4.1-mini
WRITER_MODEL=gpt-4.1-mini
INTRO_MODEL=gpt-4.1-mini

# ── Marka sitesi grounding (opsiyonel ama önerilir) ──────────────────────
# Markanın sitesini rendered (JS dahil) okuyup ne yaptığını temellendirir; yanlış tahmini
# önler. Yoksa ham title/meta'ya düşer (bot çalışır, grounding zayıflar).
# Anahtar: https://www.firecrawl.dev
FIRECRAWL_API_KEY=<FIRECRAWL_API_KEY>

# ── Referans portföyü (Notion — opsiyonel) ───────────────────────────────
# Teklif maillerine eklenecek geçmiş iş örnekleri bir Notion DB'sinden okunur. Kullanmak
# istemezsen NOTION_PORTFOLIO_DB_ID'yi boş bırak (teklif referanssız çıkar, bot yine çalışır).
# Notion entegrasyon token'ı: https://www.notion.so/my-integrations
NOTION_TOKEN=<NOTION_TOKEN>
NOTION_TOKEN_2=<NOTION_TOKEN>           # opsiyonel yedek token
NOTION_PORTFOLIO_DB_ID=<NOTION_DB_ID>   # boşsa portföy devre dışı
# DB property adların farklıysa burada eşle (varsayılanlar TR başlıklar):
# NOTION_PROP_BRAND=Marka
# NOTION_PROP_CATEGORY=Kategori
# NOTION_PROP_PLATFORM=Platform
# NOTION_PROP_VIEWS=İzlenme
# NOTION_PROP_TOPIC=Konu
# NOTION_PROP_URL=URL
# Portföy kategorileri (LLM markayı bunlardan birine eşler; kendi nişine göre düzenle):
# PORTFOLIO_CATEGORIES=AI Video, AI Yazı, E-ticaret, AI Genel

# ── Fiyatlar / paketler (kendi rate card'ın) ─────────────────────────────
PRICE_SHORT=$800       # kısa-form video paketi
PRICE_LONG=$2000       # uzun-form (YouTube) video
PRICE_BUNDLE=$2500     # paket (kısa + uzun birlikte)
OFFER_VARIANTS=3       # yöneticiye bırakılacak ayrı teklif draftı sayısı (1-3)

# ── İş birliği kapsamı (niche_fit kararı) ────────────────────────────────
# Otomatik karşılanacak / taslak bırakılacak markaları belirler. Kendi nişine göre yaz.
# Boş bırakırsan kod içindeki örnek (tech/dijital) kapsam kullanılır. Detay: config.py SCOPE_NOTE.
# SCOPE_NOTE=

# ── Uyarı maili (denetim cron'u — opsiyonel) ─────────────────────────────
# review.py sorun bulursa buraya tek mail atar. Üçü de boşsa uyarı atlanır (loga yazılır).
# Resend: https://resend.com (doğrulanmış domain'den göndermek auth uyarılarını önler).
RESEND_API_KEY=<RESEND_API_KEY>
ALERT_EMAIL_TO=<EMAIL>                 # uyarının gideceği adres (genelde kendi adresin)
ALERT_EMAIL_FROM=                      # doğrulanmış gönderen, ör. "Alerts <alerts@yourdomain.com>"

# ── Davranış / güvenlik anahtarları ──────────────────────────────────────
SCAN_DAYS=7
MAX_THREADS=25
LABEL_PREFIX=Inbound                   # Gmail etiketi ön eki (Inbound/Islendi vb.)
DRY_RUN=0              # 1 -> hiç gönderme/taslak, sadece logla (güvenli test)
AUTO_SEND_INTRO=1      # 0 -> emin durumda bile tanıştırmayı taslak bırak (acil fren)
# Israrcı aracı ajansları engelle (virgüllü domain/kelime), ör: SENDER_BLOCKLIST=aha.inc,birajans
SENDER_BLOCKLIST=
