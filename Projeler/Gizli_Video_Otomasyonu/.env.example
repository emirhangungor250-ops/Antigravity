# Gizli Video Otomasyonu — gerekli env değişkenleri
# Bu dosyayı `.env` olarak kopyalayıp doldur.
# Lokal'de bunlar master.env'den de yüklenebilir; Railway/sunucuda panele girilir.

# --- YouTube sahip token'ı (gizli video listeleme + altyazı indirme) ---
# OAuth scope: youtube.force-ssl. Token JSON'unun TAMAMINI tek satır olarak yapıştır.
YOUTUBE_FORCESSL_TOKEN_JSON=

# Token'ı bir komşu YouTube projesiyle ortak kullanıyorsan o projenin klasör adı
# (lokal dosya yolu için). Varsayılan: YouTube_Otomasyonu
FORCESSL_PROJECT_DIR_NAME=YouTube_Otomasyonu

# --- Google (Drive yazma + mail gönderme) hesabı (drive.file + gmail.send) ---
# Token JSON'unun TAMAMINI tek satır olarak yapıştır.
GOOGLE_OUTREACH_TOKEN_JSON=

# --- Senin YouTube kanalın ---
YOUTUBE_CHANNEL_ID=<YOUTUBE_CHANNEL_ID>

# --- Notion ---
# https://www.notion.so/my-integrations -> internal integration secret
NOTION_SOCIAL_TOKEN=<NOTION_TOKEN>
# Video planı/script veritabanının ID'si (32 haneli)
NOTION_DB_REELS_YT=<NOTION_DB_ID>

# --- Açıklama motoru için OpenAI (ucuz/bedava katman) ---
# Bu yoksa açıklama üretimi durur (pahalı modele düşmez). Politika: pahalı model yasak.
OPENAI_API_KEY=<OPENAI_API_KEY>

# --- Haber alıcıları (virgülle birden çok adres) ---
NOTIFY_EMAILS=<EMAIL>
# Belirsiz eşleşmede "kime sorulacağı" (boşsa ilk NOTIFY_EMAILS adresine sorulur)
ADMIN_EMAIL=<EMAIL>

# --- Komşu motor klasör adları (bu paketteki varsayılanlar) ---
# Açıklama motoru ve kapak motoru klasör adlarını değiştirdiysen burada güncelle.
ACIKLAMA_ENGINE_DIR_NAME=Youtube_Aciklama_Otomasyonu
KAPAK_ENGINE_DIR_NAME=Otonom_Kapak_Uretici

# --- Güvenlik ---
# 1 = kuru çalışma (mail/Drive/kapak YOK, sadece gösterir). Canlı için 0.
DRY_RUN=1

# Eşleştirme güven eşiği: altıysa yöneticiye sorar, körlemesine yazmaz
MATCH_MIN_SCORE=0.45
MATCH_MIN_GAP=0.12
