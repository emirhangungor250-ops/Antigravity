# --- Notion ---
NOTION_SOCIAL_TOKEN=
NOTION_X_DB_ID=                  # Twitter_Text_Paylasim ile aynı DB (carousel propertyleri eklenir)
NOTION_DB_OPS_LOG=               # Ops logging için (opsiyonel)

# --- Kie AI ---
KIE_API_KEY=
KIE_MODEL=nano-banana-2          # default; gpt-image-2-text-to-image düzelirse switch et

# --- Vision Review (Gemini) ---
GEMINI_API_KEY=

# --- LLM (Carousel Planner + Caption) ---
ANTHROPIC_API_KEY=
LLM_PROVIDER=anthropic           # anthropic | openai
WRITER_MODEL=claude-opus-4-7
OPENAI_API_KEY=                  # opsiyonel fallback

# --- ImgBB (CDN) ---
IMGBB_API_KEY=

# --- Mail / Approval ---
APPROVAL_BASE_URL=               # https://twitter-onay-api.up.railway.app
APPROVAL_SECRET=                 # twitter-onay-api ile aynı secret

# --- Carousel davranış ---
ENV=production                   # development => DRY_RUN
DRY_RUN=0
SLIDE_COUNT=7                    # default; planner gerekirse 5-9 arası dinamik
VISION_SCORE_THRESHOLD=7
VISION_MAX_RETRY=2
BODY_FORMAT=bullets_highlighted  # paragraph|bullets|numbered|highlighted|bullets_highlighted

# --- RUN_MODE override (cron|generate|mail|migrate) ---
RUN_MODE=cron
