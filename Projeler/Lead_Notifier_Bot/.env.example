# --- Google Sheets ---
SPREADSHEET_ID=               # İzlenecek Google Sheet dosya ID'si
SHEET_TAB=Sheet1              # İzlenecek tab adı

# --- Telegram ---
TELEGRAM_BOT_TOKEN=           # @BotFather'dan alınan bot tokeni
TELEGRAM_CHAT_ID=             # Bildirim gönderilecek chat/grup ID'si

# --- E-posta ---
NOTIFY_EMAIL=                 # Yeni lead bildirimini alacak e-posta
SENDER_EMAIL=                 # Gönderen e-posta adresi

# --- Google kimlik doğrulama ---
GOOGLE_SERVICE_ACCOUNT_JSON=  # Servis hesabı JSON (Railway'de base64/düz JSON)
GOOGLE_OUTREACH_TOKEN_JSON=   # Gmail/Sheets OAuth token JSON (e-posta gönderimi için)
GOOGLE_OAUTH_HELPER_PATH=     # google_auth yardımcı modülünün klasörü (opsiyonel, lokal)

# --- Davranış ---
POLL_INTERVAL_SECONDS=300     # Sheet kontrol sıklığı (saniye)
MAX_BATCH_SIZE=10             # Tek döngüde gönderilecek max bildirim (spam koruması)
