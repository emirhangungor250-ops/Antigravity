# --- Çalışma modu ---
ENV=production                # production | development (development => DRY_RUN)
DRY_RUN=0                     # 1 => gerçek API çağrısı yapmaz
RUN_MODE=cron                 # cron | force (force_post.py için)

# --- Perplexity (AI haber araştırması) ---
PERPLEXITY_API_KEY=
PERPLEXITY_BASE_URL=https://api.perplexity.ai

# --- OpenAI (post metni + görsel prompt) ---
OPENAI_API_KEY=

# --- Kie AI (görsel üretimi) ---
KIE_API_KEY=

# --- Typefully (LinkedIn yayını) ---
TYPEFULLY_API_KEY=
TYPEFULLY_SOCIAL_SET_ID=      # Typefully Settings > Social Sets'ten kopyalanan sayısal ID

# --- Notion ---
NOTION_SOCIAL_TOKEN=          # Notion entegrasyon tokeni
NOTION_X_DB_ID=               # Sosyal medya draft DB ID'si
NOTION_LINKEDIN_DB_ID=        # Opsiyonel: eski LinkedIn-only DB (dedup için)
NOTION_DB_OPS_LOG=            # Opsiyonel: merkezi operasyon log DB ID'si
