# --- Çalışma modu ---
ENV=production                # production | development (development => DRY_RUN)
DRY_RUN=0                     # 1 => gerçek API çağrısı yapmaz
RUN_MODE=cron                 # cron | force

# --- Typefully (LinkedIn yayını) ---
TYPEFULLY_API_KEY=
TYPEFULLY_LINKEDIN_SOCIAL_SET_ID=   # LinkedIn-only Typefully social set ID'si (sayısal)

# --- Groq (uygunluk filtresi + caption üretimi) ---
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL=llama-3.3-70b-versatile

# --- Notion ---
NOTION_SOCIAL_TOKEN=          # Notion entegrasyon tokeni
NOTION_DB_REELS_KAPAK=        # Kaynak video DB ID'si (Reels & YouTube)
NOTION_LINKEDIN_DB_ID=        # LinkedIn paylaşım log DB ID'si
NOTION_DB_OPS_LOG=            # Opsiyonel: merkezi operasyon log DB ID'si

# --- Google (Drive video indirme) ---
GOOGLE_SERVICE_ACCOUNT_JSON=  # Servis hesabı JSON (Railway'de base64)

# --- İçerik profili ---
CREATOR_PROFILE=AI/teknoloji + iş otomasyonu içerik üreticisi, B2B kitle (girişimciler, profesyoneller)

# --- Video işleme ---
VIDEO_PATTERN_PRIORITY=tiktok,insta   # Tercih edilen video kaynak sırası
MAX_VIDEO_BYTES=524288000             # ~500MB pratik üst sınır
REENCODE_OVER_BYTES=209715200         # ~200MB üstü videolar yeniden encode edilir
