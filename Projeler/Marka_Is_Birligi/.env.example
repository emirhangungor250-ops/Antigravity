# Marka_Bulma_Outreach — Environment Variables
# Bu dosyayı `.env` olarak kopyalayıp doldur.
# Production: Railway servis env'inde aynı isimlerle tanımla.

# ── Notion ───────────────────────────────────────────────────────────────
NOTION_SOCIAL_TOKEN=<NOTION_TOKEN>
NOTION_DB_BRAND_REACHOUT=<NOTION_DB_ID>
NOTION_DB_BRAND_LOGS=<NOTION_DB_ID>
NOTION_DB_OPS_LOG=<NOTION_DB_ID>

# ── Apify (Instagram scraping) ──────────────────────────────────────────
# Birden fazla anahtar token rotasyonu için _1, _2 ... ile tanımla.
APIFY_API_KEY_1=<APIFY_API_KEY>
APIFY_API_KEY_2=<APIFY_API_KEY>

# ── Hunter.io (email enrichment + verification) ─────────────────────────
HUNTER_API_KEY=<HUNTER_API_KEY>

# ── OpenAI (GPT email kişiselleştirme) ──────────────────────────────────
OPENAI_API_KEY=<OPENAI_API_KEY>

# ── Gmail (outreach gönderim — OAuth) ───────────────────────────────────
# Outreach maillerini gönderen Gmail adresi.
SENDER_EMAIL=<EMAIL>
# Gmail API OAuth2 token JSON'u (base64 encode edilmiş) — Railway için.
# Lokal: gmail credentials + token JSON dosyalarını oauth klasörüne koy.
GOOGLE_OAUTH_TOKEN_JSON=

# ── Telegram (haftalık rapor) ───────────────────────────────────────────
TELEGRAM_BOT_TOKEN=<TELEGRAM_BOT_TOKEN>
TELEGRAM_CHAT_ID=<TELEGRAM_CHAT_ID>

# ── Davranış flag'leri ─────────────────────────────────────────────────
# `risky` Hunter sonuçlarını da göndermek için (default: false).
ALLOW_RISKY_EMAILS=false

# Health server portu (Railway otomatik atar)
PORT=8080
