# Otel Danışma Asistanı — Ortam Değişkenleri
# .env olarak kopyalayıp doldurun. Tüm değerler placeholder; kendi anahtarlarınızı girin.
# Hiçbir gerçek anahtar repoya gömülü değildir.

# === Tesis kimliği (sistem promptu + iletişim yönlendirme) ===
BUSINESS_NAME=<Tesisinizin adı, örn: Deniz Resort & Spa>
CONTACT_PHONE=<rezervasyon telefonu>
CONTACT_EMAIL=<rezervasyon e-postası>
GROUP_THRESHOLD=20          # bu sayı ve üzeri kişi -> grup ekibine yönlendir
CHILD_MAX_AGE=11            # bu yaş ve altı "çocuk", üzeri "yetişkin" sayılır

# === Phase 1: Fiyat servisi (HotelRunner booking engine) ===
# Tesisinizin HotelRunner booking engine host'u. Rezervasyon sayfanızın URL'inden alın.
# Örn: https://<tesisinizin-adi>.hotelrunner.com
HOTELRUNNER_HOST=<https://tesis-adi.hotelrunner.com>
# Para birimi / dil / ülke (booking engine parametreleri).
HOTELRUNNER_CURRENCY=TRY
HOTELRUNNER_LOCALE=tr
HOTELRUNNER_COUNTRY=TR
# Bazı booking engine'ler fiyatı ziyaretçi IP ülkesine göre belirler. Sunucunuz yurt
# dışındaysa, doğru yerel fiyat için yerel bir genel IP girin. Gerekmiyorsa BOŞ bırakın.
HOTELRUNNER_GEO_IP=
# HTTP zaman aşımı (sn) ve SSL doğrulama. Üretimde SSL=1 KALMALI.
# HOTELRUNNER_TIMEOUT=20
# HOTELRUNNER_VERIFY_SSL=1   # SADECE lokal SSL-kesme ortamında 0 yapılır

# Opsiyonel: /price endpoint'ini korumak için paylaşılan anahtar. Set edilirse istek
# X-Price-Key header'ı taşımalı. Boş = koruma kapalı.
PRICE_SHARED_SECRET=

# === Phase 2: ManyChat botu ===
# LLM: Maliyet politikası gereği Groq (ucuz workhorse). Opus/Sonnet API yasak.
# Anahtar: https://console.groq.com
GROQ_API_KEY=<GROQ_API_KEY>
# Konuşma hafızası (opsiyonel ama önerilir). Supabase projenizden alın.
SUPABASE_URL=<SUPABASE_URL>
SUPABASE_SERVICE_ROLE_KEY=<SUPABASE_SERVICE_ROLE_KEY>
# Supabase'deki hafıza tablosunun adı (varsayılan: chat_memory)
# CHAT_MEMORY_TABLE=chat_memory

# Kendi ManyChat hesabınızın API token'ı: ManyChat -> Settings -> API
MANYCHAT_TOKEN=<MANYCHAT_TOKEN>
# ManyChat custom field + flow id eşlemesi (JSON). HER hesaba özeldir; kendi id'lerinizi
# girin. Boş bırakılırsa manychat.py içindeki placeholder id'ler kullanılır (gerçek
# gönderim çalışmaz). Yapı için manychat.py _DEFAULT_PLATFORMS bölümüne bakın.
# Örn: MANYCHAT_PLATFORMS={"Instagram":{"answer_field":"123","link_field":"124",...}}
MANYCHAT_PLATFORMS=

# Test: 1 ise ManyChat'e gerçekten göndermez, sadece log'a yazar.
DRY_RUN=0
# Webhook koruması (opsiyonel): set ise istek X-Webhook-Secret taşımalı.
WEBHOOK_SECRET=
# Model override (varsayılanlar yeterli):
# AGENT_MODEL=openai/gpt-oss-120b
# WHISPER_MODEL=whisper-large-v3
# HISTORY_WINDOW=15

# === Görsel betimleme (opsiyonel) ===
# Misafir görsel gönderirse gpt-4o-mini ile kısa Türkçe betimleme yapılır, ajana bağlam olur.
# MALİYET POLİTİKASI: SADECE gpt-4o-mini. gpt-4o / Opus / Sonnet YASAK (kod da bunu zorlar).
# Anahtar: https://platform.openai.com/api-keys
OPENAI_API_KEY=<OPENAI_API_KEY>
# VISION_MODEL=gpt-4o-mini    # DEĞİŞTİRME (politika gereği sadece bu model)
# VISION_MAX_MB=8             # gpt-4o-mini sert görsel boyut limiti
# MEDIA_PROBE_TIMEOUT=5       # medya Content-Type probe zaman aşımı (sn)

# === Mesaj birleştirme / burst coalesce (opsiyonel) ===
# Misafir art arda birkaç kısa mesaj atarsa hepsi tek pencerede toplanıp TEK cevap üretilir.
# Sadece zamanlama; LLM maliyeti yok. Test için pencereler kısaltılabilir.
# COALESCE_INITIAL_MS=3000    # ilk toplama penceresi
# COALESCE_STRAGGLER_MS=1500  # artçı pencere
# COALESCE_MAX_ITER=4         # iç/dış döngü üst sınırı
# COALESCE_POOL_SIZE=16       # ayrılmış worker havuzu boyutu
