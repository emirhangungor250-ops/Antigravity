# Otonom Kapak Üreticisi — Ortam Değişkenleri
# Bu dosyayi .env olarak kopyalayin ve kendi degerlerinizle doldurun.

# Hangi platform icin kapak uretilecek: reels veya youtube
COVER_TYPE=reels

# production = gercek uretim, development = dry-run (API cagrisi yapmaz)
ENV=development
# ENV=production iken bile dry-run zorlamak icin 1 yap (opsiyonel)
DRY_RUN=0
# 1 = sürekli calisan worker modu, 0/bos = tek seferlik cron calismasi (opsiyonel)
LOOP=0

# --- Notion ---
# Notion entegrasyon token'i (https://www.notion.so/my-integrations)
NOTION_SOCIAL_TOKEN=<NOTION_TOKEN>
# Video listesini tutan Notion database ID'leri
NOTION_DB_REELS_KAPAK=<NOTION_DB_ID>
NOTION_DB_YOUTUBE_ISBIRLIKLERI=<NOTION_DB_ID>
# Operasyon loglarinin yazildigi Notion database ID'si
NOTION_DB_OPS_LOG=<NOTION_DB_ID>

# --- Gorsel uretim ---
# Kie AI API anahtari (gorsel uretim)
KIE_API_KEY=<KIE_API_KEY>
# Google Gemini API anahtari (tema uretimi + vision review)
GEMINI_API_KEY=<GOOGLE_API_KEY>
# ImgBB API anahtari (referans gorsel hosting)
IMGBB_API_KEY=<IMGBB_API_KEY>
# screenshotapi.net token'i — YouTube kapaginda ekran goruntusu adimi icin
# (opsiyonel — bos birakilirsa screenshot adimi atlanir)
SCREENSHOT_API_KEY=<SCREENSHOT_API_KEY>

# --- Google Drive ---
# Google OAuth token'i JSON string olarak (uretilen kapaklarin yuklenmesi icin)
GOOGLE_OUTREACH_TOKEN_JSON=<GOOGLE_OAUTH_TOKEN_JSON>
