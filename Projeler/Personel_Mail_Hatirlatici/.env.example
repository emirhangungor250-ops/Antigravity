# ── Gmail OAuth ──
# İzlenen personel hesabının e-posta adresi
STAFF_EMAIL=staff@example.com
# Gmail OAuth token — Railway'de JSON string olarak set edilir.
# Lokal'de bunun yerine data/gmail-token.json dosyası kullanılabilir.
GMAIL_TOKEN_JSON=

# ── Groq LLM ──
GROQ_API_KEY=<GROQ_API_KEY>

# ── Notion ──
NOTION_TOKEN=<NOTION_TOKEN>
# Thread tracker DB id'si (her mail thread'i için bir satır)
NOTION_DB_THREADS=<NOTION_DB_ID>

# ── Opsiyonel: Notion pipeline entegrasyonu ──
# Mail dışı kanaldan gelen işleri ayrı bir Notion DB'sinden çekmek istersen doldur.
# Boş bırakırsan pipeline tarama tamamen atlanır.
NOTION_DB_PIPELINE=
# Pipeline DB'ndeki hangi Status değerleri "hareket bekliyor" sayılsın (virgülle ayır)
PIPELINE_TARGET_STATUSES=Hazır,Devam Ediyor,Onay Bekliyor
# Pipeline DB'ndeki "ilgili taraf" kolonunun adı
PIPELINE_COLLAB_PROP=Taraf

# ── Bildirim ──
# Digest raporları bu adrese gider
ALERT_EMAIL=admin@example.com
# Opsiyonel ek alıcılar (virgülle ayrılmış)
ALERT_CC=

# ── Buton webhook'u (opsiyonel — mute/snooze butonları için) ──
# webhook_server.py'nin public URL'i. Boşsa mailde buton görünmez.
WEBHOOK_BASE_URL=
# Buton URL'lerini imzalamak için rastgele uzun bir secret
BUTTON_HMAC_SECRET=
