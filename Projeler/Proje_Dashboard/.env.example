# Proje Dashboard — token referansı.
#
# Bu dosyayı .env olarak kopyala ve doldur.
# (Antigravity monorepo içinde çalışıyorsan _knowledge/credentials/master.env
#  de okuma kaynağı olabilir; burası referans / override içindir.)

# --- ZORUNLU ---
RAILWAY_TOKEN=             # https://railway.com/account/tokens

# --- Notion (DB sayaçları için) ---
NOTION_SOCIAL_TOKEN=       # Birincil Notion workspace token'ı
NOTION_API_TOKEN=          # (opsiyonel) farklı bir workspace için ikinci token
# İzlemek istediğin her Notion DB için bir ID. notion_collector.py içindeki
# DB_SPECS listesindeki env var adlarıyla eşleşmeli.
NOTION_DB_ORNEK_ONAY=
NOTION_DB_ORNEK_LOG=

# --- Canlı maliyet collectors (opsiyonel — yoksa 'veri yok' döner) ---
ELEVENLABS_API_KEY=        # https://elevenlabs.io/app/settings/api-keys
HUNTER_API_KEY=            # https://hunter.io/api-keys
FIRECRAWL_API_KEY=         # https://www.firecrawl.dev/app/api-keys
APIFY_API_KEY_1=           # https://console.apify.com/account/integrations
APIFY_API_KEY_2=           # (opsiyonel — ikinci hesap)
REPLICATE_API_TOKEN=       # https://replicate.com/account/api-tokens
MANYCHAT_API_TOKEN=        # https://app.manychat.com/settings/api

# --- Admin keys (varsa otomatik USD çekilir) ---
OPENAI_ADMIN_API_KEY=      # Platform → Settings → Organization → Admin Keys (api.usage.read scope)
ANTHROPIC_ADMIN_API_KEY=   # Console → Settings → Organization → API Keys → Admin Keys

# --- Diğer ---
KIE_API_KEY=
KIE_BASE_URL=              # opsiyonel; default https://api.kie.ai
