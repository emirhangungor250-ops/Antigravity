# Reels Script Pipeline — Environment Variables
# Bu dosya bir referanstır. Kendi .env dosyanı oluştur ve doldur.

# ─── LLM (Anthropic Claude) ──────────────────────────────────
ANTHROPIC_API_KEY=

# ─── Reels indirme (Apify Instagram Reel Scraper) ────────────
APIFY_API_KEY_1=
APIFY_API_KEY_2=

# ─── Transkripsiyon (HappyScribe) ────────────────────────────
HAPPYSCRIBE_API_KEY=
# Opsiyonel: kendi terim sözlüğünüzü HappyScribe UI'da yaratıp ID'yi koyun
HAPPYSCRIBE_ORG_GLOSSARY_ID=

# ─── Notion ──────────────────────────────────────────────────
NOTION_REELS_TOKEN=

# Hedef DB (pipeline buraya yazar)
NOTION_REELS_PROD_DB_ID=<NOTION_DB_ID>
NOTION_REELS_PROD_DATA_SOURCE_ID=<NOTION_DATA_SOURCE_ID>

# Test DB (regression için isteğe bağlı)
NOTION_REELS_TEST_DB_ID=<NOTION_DB_ID>
NOTION_REELS_TEST_DATA_SOURCE_ID=<NOTION_DATA_SOURCE_ID>

# Style corpus (genelde aynı prod DB ile)
NOTION_STYLE_CORPUS_DB_ID=<NOTION_DB_ID>
NOTION_STYLE_CORPUS_DATA_SOURCE_ID=<NOTION_DATA_SOURCE_ID>

# Test parent + custom emoji (opsiyonel)
NOTION_TEST_PARENT_PAGE_ID=<NOTION_PAGE_ID>
NOTION_CUSTOM_EMOJI_CLAUDECODE_ID=<NOTION_EMOJI_ID>

# ─── Supabase (state + style corpus embedding + storage) ─────
REELS_SUPABASE_URL=
REELS_SUPABASE_ANON_KEY=
REELS_SUPABASE_PROJECT_REF=

# ─── Embedding (Voyage) ──────────────────────────────────────
VOYAGE_API_KEY=
EMBEDDING_MODEL=voyage-3

# ─── Google Drive (asset brief Doc'u için) ───────────────────
# OAuth refresh token kullanılır. drive.file scope gerekir.
GOOGLE_DRIVE_REELS_PARENT_FOLDER_ID=<GOOGLE_DRIVE_FOLDER_ID>
REELS_DRIVE_OAUTH_ACCOUNT=default

# ─── Asset araması ───────────────────────────────────────────
# Anthropic native web_search tool kullanılır (ek key gerekmez).

# ─── Runtime ─────────────────────────────────────────────────
LOG_LEVEL=INFO
ENV=local   # local | production
