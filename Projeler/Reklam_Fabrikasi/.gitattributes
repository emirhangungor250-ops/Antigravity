# Normalize line endings across platforms.

* text=auto

*.sh   text eol=lf
*.py   text eol=lf
*.md   text eol=lf
*.json text eol=lf
*.mjs  text eol=lf
*.js   text eol=lf
*.yml  text eol=lf
*.yaml text eol=lf

*.ps1  text eol=crlf
*.bat  text eol=crlf

*.png  binary
*.jpg  binary
*.jpeg binary
*.mp4  binary
*.webp binary
