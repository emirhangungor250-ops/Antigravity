# Sesli Asistan (JARVIS) — ortam değişkenleri
# Bu dosyayı .env olarak kopyalayın ve <...> alanlarını kendi değerlerinizle doldurun.

# === ZORUNLU — beyin (LLM) ===
# OpenRouter anahtarı. Tek anahtarla birçok modele erişirsiniz. openrouter.ai
OPENROUTER_API_KEY=<OPENROUTER_API_KEY>

# === ZORUNLU — ses (TTS) ===
# En az birini doldurun. ElevenLabs Türkçe sesi iyi okur. elevenlabs.io
ELEVENLABS_API_KEY=<ELEVENLABS_API_KEY>
# Kullanmak istediğiniz sesin kimliği (ElevenLabs panelinden alınır):
ELEVENLABS_VOICE_ID=<ELEVENLABS_VOICE_ID>
# ELEVENLABS_MODEL=eleven_turbo_v2_5      # Türkçe-uyumlu, düşük gecikme (varsayılan)

# Alternatif ses motoru — ElevenLabs yerine Fish Audio kullanacaksanız. fish.audio
# FISH_API_KEY=<FISH_API_KEY>
# FISH_VOICE_ID=<FISH_VOICE_ID>

# === Model seçimi (opsiyonel) ===
# Varsayılan ucuz/hızlı modeller. Daha güçlü model isterseniz buradan değiştirin.
JARVIS_MODEL=openai/gpt-4o-mini
JARVIS_SMALL_MODEL=openai/gpt-4o-mini

# === Kişiselleştirme (opsiyonel) ===
# Asistanın size nasıl hitap edeceği. Boş bırakırsanız isimsiz "efendim" kullanılır.
USER_NAME=<USER_NAME>
# HONORIFIC=efendim

# Takvim hesapları (virgülle ayrılmış e-postalar). "auto" = sistemdeki varsayılan.
CALENDAR_ACCOUNTS=auto

# === Hava durumu (opsiyonel) ===
# WEATHER_LATITUDE=
# WEATHER_LONGITUDE=
# WEATHER_LOCATION_LABEL=
# WEATHER_UNIT=celsius
