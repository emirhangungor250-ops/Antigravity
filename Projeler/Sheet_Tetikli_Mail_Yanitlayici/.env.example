# ── Google OAuth token'ları ──
# Railway'de JSON string olarak set edilir. Lokal'de data/ altına dosya da koyabilirsin.
# Aynı hesabı hem mail hem sheet için kullanacaksan iki değişkene aynı token'ı koy.
GMAIL_TOKEN_JSON=
SHEETS_TOKEN_JSON=

# ── Google Sheet ──
SHEET_ID=<GOOGLE_SHEET_ID>
TAB_NAME=Sheet1
# A'dan hangi sütuna kadar veri okunsun
LAST_COL=M
# Durum sütununa yazılacak header metni
STATUS_HEADER=Mail Durumu

# ── Sütun haritası (kendi Sheet'inin düzenine göre ayarla) ──
# Hangi sütun mail'i tetikler (checkbox), hangi sütuna durum yazılır
TRIGGER_COL=K
STATUS_COL=M
# Alıcı e-postası
EMAIL_COL=E
# Mail kişiselleştirmesi için bağlam sütunları (opsiyonel)
NAME_COL=G
SURNAME_COL=H
BRAND_COL=B
ROLE_COL=A
EMPLOYEES_COL=C
PHONE_COL=D
NEED_COL=F
NOTES_COL=J

# ── Mailin amacı ──
# LLM'e mailin ne yapacağını tek cümleyle anlatır. Kendi senaryona göre yaz.
MAIL_PURPOSE=Formda bıraktığı telefon numarasına ulaşılamayan kişiye, doğru numarayı bu maile cevap olarak iletmesini nazikçe rica et.

# ── Gönderici kimliği ──
SENDER_EMAIL=sender@example.com
SENDER_NAME=Ekip

# ── OpenAI (mail metni kişiselleştirmesi — opsiyonel) ──
# Boş bırakırsan deterministik şablon kullanılır.
OPENAI_API_KEY=<OPENAI_API_KEY>
OPENAI_MODEL=gpt-4.1-mini

# ── Davranış ──
DRY_RUN=0
POLL_INTERVAL_SECONDS=300
