# ─── Çalışma Modu ─────────────────────────────────────────────
ENV=production            # development => DRY_RUN otomatik açık (sıfır maliyet test)
DRY_RUN=0

# ─── Üretim API'leri (zorunlu) ────────────────────────────────
# Kie AI — Gemini Omni video + nano-banana-2 görsel. Anahtar: kie.ai
KIE_API_KEY=<KIE_API_KEY>
# LLM beyni (senarist + dizi kitabı). Anahtar: console.anthropic.com
# (İstersen OpenAI'a geçebilirsin; brain/client.py'i kendi sağlayıcına göre uyarla.)
ANTHROPIC_API_KEY=<ANTHROPIC_API_KEY>
# Referans görsellerin public host'u. Anahtar: api.imgbb.com
IMGBB_API_KEY=<IMGBB_API_KEY>

# ─── Modeller ─────────────────────────────────────────────────
# Maliyet uyarısı: pahalı model (Opus/Sonnet) varsayılan OLMASIN — senaryo
# üretimi için ucuz model fazlasıyla yeter. Pahalı model gerçekten gerekiyorsa
# bilerek değiştir; aksi halde ucuz/uygun modelde kal.
BRAIN_MODEL=claude-haiku-4-5               # Senarist/dizi kitabı modeli (ucuz varsayılan)
QC_MODEL=claude-haiku-4-5                  # Kare-tutarlılık kontrolü (ucuz vision)

# ─── Çıktı ────────────────────────────────────────────────────
DRIVE_FOLDER_URL=                          # Bölümlerin yükleneceği Drive klasörü; boşsa ilk
                                           # çalıştırmada bir kök klasör otomatik açılır
GOOGLE_OUTREACH_TOKEN_JSON=                # Drive yüklemesi için OAuth token JSON'ı (drive.file scope).
                                           # Cloud'da zorunlu; lokalde token dosyasından okunur.

# ─── Maliyet ──────────────────────────────────────────────────
KIE_CREDITS_PER_USD=200
MAX_EPISODE_CREDITS=0                      # 0 = limitsiz; >0 ise sahne göndermeden önce bütçe kontrolü

# ─── Cron uyumu (lokal kullanımda boş bırak) ──────────────────
MODE=
SERI_SLUG=
