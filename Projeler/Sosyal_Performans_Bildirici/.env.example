# ── Ortam ──
ENV=development          # development (DRY_RUN açık) veya production
DRY_RUN=0                # 1 = mail/Notion'a yazma, sadece logla

# ── Apify ──
# En az bir anahtar zorunlu. Birden fazla verirsen quota dolunca rotasyon yapar.
APIFY_API_KEY_1=<APIFY_API_KEY>
# APIFY_API_KEY_2=<APIFY_API_KEY>
# Apify Store actor id'leri — gerekirse kendi tercih ettiğin actor'larla değiştir.
APIFY_INSTAGRAM_ACTOR=apify/instagram-profile-scraper
APIFY_TIKTOK_ACTOR=
APIFY_YOUTUBE_ACTOR=

# ── İzlenecek hesaplar ──
IG_USERNAME=your_instagram_handle
TIKTOK_USERNAME=your_tiktok_handle
YOUTUBE_SEARCH_QUERY=your channel name
# YouTube sonuçlarını kanala göre filtrelemek için anahtar kelimeler (virgülle ayır)
YOUTUBE_CHANNEL_KEYWORDS=your channel name

# ── İzlenme barajları ──
IG_VIEW_THRESHOLD=200000
TIKTOK_VIEW_THRESHOLD=100000
YT_SHORTS_THRESHOLD=100000
YT_LONG_THRESHOLD=10000
LOOKBACK_DAYS=7

# ── LLM (opsiyonel — AI özet için) ──
GROQ_API_KEY=<GROQ_API_KEY>

# ── Gmail OAuth ──
# Production: token JSON'u buraya string olarak koy.
# Lokal: bunun yerine data/gmail-token.json dosyası kullanılabilir.
GMAIL_OAUTH_JSON=

# ── Mail adresleri ──
REPORT_TO=report-recipient@example.com
REPORT_FROM=Sosyal Performans Botu <sender@example.com>
TECH_ERROR_TO=admin@example.com

# ── Notion (opsiyonel — state + ops log için) ──
# Boş bırakırsan state lokal JSON dosyasında tutulur, ops log sadece konsola basar.
NOTION_TOKEN=<NOTION_TOKEN>
NOTION_DB_NOTIFIED_VIDEOS=<NOTION_DB_ID>
NOTION_DB_OPS_LOG=<NOTION_DB_ID>
