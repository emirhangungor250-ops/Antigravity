# Sosyal Video ManyChat Yazıcı — Ortam Değişkenleri
# Bu dosyayı `.env` olarak kopyalayıp doldurun. Lokal'de paket kök
# _knowledge/credentials/master.env varsa otomatik yüklenir; bu dosya
# tek bir servis/cron için env referansıdır.

# ─── Çalışma ───────────────────────────────────────────────────
# 1 => Notion'a yazma; sadece üretip konsola bas (kuru test).
DRY_RUN=0
# Tek koşumda işlenecek max video (maliyet + gözden geçirilebilirlik).
MAX_VIDEOS_PER_RUN=5
# Script bu karakter sayısının altındaysa "metni yok" sayılır, atlanır.
MIN_SCRIPT_CHARS=150

# ─── LLM (sadece manuel yedek koşum — main.py) ─────────────────
# Üretim akışını API'siz bir cloud routine'de de çalıştırabilirsin; main.py +
# core/llm.py yalnızca manuel yedek hattıdır. Maliyet bilinci: pahalı modeli
# varsayılan YAPMA. Varsayılan ucuz/küçük model; üst sınıf model istersen bilinçli seç.
MANYCHAT_MODEL=claude-haiku-4-5
# Anthropic API anahtarı (manuel yedek hattı için). https://console.anthropic.com/
ANTHROPIC_API_KEY=<ANTHROPIC_API_KEY>

# ─── Notion ────────────────────────────────────────────────────
# Notion entegrasyon token'ı. https://www.notion.so/my-integrations
NOTION_SOCIAL_TOKEN=<NOTION_TOKEN>
# Hedef video DB'sinin id'si (reels + youtube tek DB olabilir).
# Notion'da DB'yi aç; URL'deki 32-hane hex parça DB id'sidir.
NOTION_DB_REELS_KAPAK=<NOTION_DB_ID>

# ─── Hedef seçimi (opsiyonel — kendi şemana göre) ──────────────
# İşlenecek video ikonları (sayfa custom emoji adından türetilen sınıf), virgülle ayır.
# Boş bırakırsan varsayılan: reels,ai-factory
NOTION_TARGET_ICONS=
# İşlenecek statü adları (Notion Status select değerleri), virgülle ayır.
# Boş bırakırsan varsayılan: Çekime Hazır, Çekildi - Edit YOK, Çekildi - Edit TAMAM, Draft Onayı Bekliyor
NOTION_TARGET_STATUSES=

# ─── İçerik kuralları (opsiyonel) ──────────────────────────────
# DM metninde istemediğin doğrudan tanıtım kelimeleri (örn. kendi topluluk/kurs adın), virgülle ayır.
BRAND_PROMO_PHRASES=
# Link butonunda YASAK domain'ler (örn. üyelik/satış platformun), virgülle ayır.
BANNED_DOMAINS=
