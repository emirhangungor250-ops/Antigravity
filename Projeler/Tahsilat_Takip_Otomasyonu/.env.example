# Tahsilat Takip Otomasyonu — Environment Variables
# Bu dosyayı .env olarak kopyala ve kendi değerlerinle doldur.

# ── Notion ───────────────────────────────────────────
# Notion entegrasyon token'ı (NOTION_SOCIAL_TOKEN öncelikli, yoksa NOTION_API_TOKEN).
NOTION_SOCIAL_TOKEN=<NOTION_TOKEN>
NOTION_API_TOKEN=<NOTION_TOKEN>

# Yayınlanan içerik/iş kayıtlarını tutan ana DB ID'si.
COLLAB_DB_ID=<NOTION_DB_ID>
# Tutar/ödeme bilgisini tutan DB ID'si (sadece okunur).
TAHSILAT_TAKIP_DB_ID=<NOTION_DB_ID>
# Mail deep-link'leri için parent page slug'ı (sayfa URL'sindeki son segment).
COLLAB_PARENT_SLUG=<NOTION_PARENT_PAGE_SLUG>

# Operational log DB ID'si (opsiyonel — boşsa sadece console'a log basar).
NOTION_DB_OPS_LOG=

# ── Notion property adları (kendi şemana göre düzenle) ───
PAYMENT_TYPE_PROP=Ödeme Tipi
PAYMENT_TYPE_SKIP_VALUE=Ödeme Yok
CONTENT_RELATION_PROP=İçerik

# ── E-posta ──────────────────────────────────────────
# Özet mailinin gideceği ve gönderileceği adres.
NOTIFY_EMAIL=<ADMIN_EMAIL>
# Merkezi OAuth modülündeki hesap anahtarı (account1 / account2).
GMAIL_ACCOUNT=account1
# Gmail API OAuth2 token (JSON string) — Railway için. Lokal'de boş bırakıp
# _knowledge/credentials/oauth/ altındaki token dosyası kullanılabilir.
GMAIL_TOKEN_JSON=
