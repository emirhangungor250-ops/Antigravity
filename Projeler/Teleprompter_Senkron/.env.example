# Teleprompter_Senkron — environment
# Bu dosyayi `.env` olarak kopyalayin, kendi degerlerinizi yazin.
# .env gizlidir, repo'ya commit edilmez.

# --- Notion ---
# Notion integration token. Script DB'nizi bu integration ile paylasin.
# Token al: https://www.notion.so/my-integrations
NOTION_REELS_TOKEN=<NOTION_TOKEN>

# Script DB'nizin ID'si (Notion DB linkindeki 32 karakterlik hex parca).
PROMPTER_NOTION_DB_ID=<NOTION_DB_ID>

# (Opsiyonel) DB'nizdeki durum/status property adi ve "hazir" degeri.
# Bos birakirsaniz varsayilan kullanilir: "Status" / "Çekime Hazır".
NOTION_STATUS_PROPERTY=
NOTION_STATUS_READY=

# --- Google Drive ---
# Teleprompter uygulamasinin Drive'da KENDI actigi klasorun ID'si
# (klasor linkindeki .../folders/<ID> parcasi). Uygulama yalnizca bu klasoru senkronlar.
PROMPTER_DRIVE_FOLDER_ID=<GOOGLE_DRIVE_FOLDER_ID>

# TAM `drive` scope'lu OAuth token (tek satir JSON). Uygulamanin klasorune yazmak icin sart.
# core/reauth_drive_full.py ile uretilir; uretilen drive-full-token.json icerigini buraya yapistirin.
# Lokal'de bu env bos birakilirsa proje kokundeki drive-full-token.json dosyasindan okunur.
GOOGLE_DRIVE_TOKEN_JSON=

# (Opsiyonel) Guvenlik kapisi: token bu domain'e ait degilse hicbir sey yazilmaz.
# Ornek: sirket.com  -> sadece o domain'in Google hesabina yazar. Bos = kapi kapali.
EXPECTED_DRIVE_DOMAIN=

# --- AI temizleme (script govdesi -> prompter metni) ---
# Birincil: OpenAI. Anahtar: https://platform.openai.com/api-keys
OPENAI_API_KEY=<OPENAI_API_KEY>
# (Opsiyonel) Model adi; bos birakirsaniz ucuz varsayilan (gpt-4o-mini) kullanilir.
OPENAI_MODEL=

# Yedek: OpenAI yoksa/patlarsa Anthropic (Claude). Anahtar: https://console.anthropic.com/
ANTHROPIC_API_KEY=<ANTHROPIC_API_KEY>
# (Opsiyonel) Model adi; bos birakirsaniz ucuz varsayilan (claude-3-5-haiku-latest) kullanilir.
ANTHROPIC_MODEL=
