# Twitter_Text_Paylasim — Environment Variables
# Lokal: bu dosyayı `.env` olarak kopyalayıp doldur veya
# _knowledge/credentials/master.env üzerinden çek.
# Production: Railway servis env'inde tanımla.

# ── Çalışma modu ────────────────────────────────────────────────────────
ENV=production
DRY_RUN=0

# ── Typefully (X + LinkedIn publish proxy) ──────────────────────────────
TYPEFULLY_API_KEY=
TYPEFULLY_SOCIAL_SET_ID=

# ── LLM (writer) ────────────────────────────────────────────────────────
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
WRITER_MODEL=claude-opus-4-7

# ── Kaynak API'ler ──────────────────────────────────────────────────────
PERPLEXITY_API_KEY=
PERPLEXITY_BASE_URL=https://api.perplexity.ai
GITHUB_TOKEN=
KIE_API_KEY=
YOUTUBE_CHANNEL_ID=

# ── Notion ──────────────────────────────────────────────────────────────
NOTION_SOCIAL_TOKEN=
NOTION_X_DB_ID=
NOTION_DB_REELS_KAPAK=
# Ops log DB ID — ops_logger.py her çalışmayı buraya yazar.
NOTION_DB_OPS_LOG=

# ── Davranış ────────────────────────────────────────────────────────────
QUALITY_THRESHOLD=8
DEDUP_DAYS=30

# ── Onay maili (Twitter_Onay_Api ile aynı sır) ──────────────────────────
APPROVAL_SECRET=
APPROVAL_API_URL=
APPROVAL_BASE_URL=

# ── Sabah özet maili (Gmail API ile gönderilir) ─────────────────────────
# Gönderici ve alıcı genelde aynı adrestir (kendine özet maili).
MAIL_SENDER=<EMAIL>
MAIL_RECIPIENT=<EMAIL>
