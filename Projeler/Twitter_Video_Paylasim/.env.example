# Twitter_Video_Paylasim — Ortam Degiskenleri
# Bu dosyayi .env olarak kopyalayin ve kendi degerlerinizi girin.

# Ortam: development (DRY-RUN) veya production
ENV=development

# Typefully (X video paylasimi proxy)
TYPEFULLY_API_KEY=<TYPEFULLY_API_KEY>
TYPEFULLY_SOCIAL_SET_ID=<TYPEFULLY_SOCIAL_SET_ID>

# (Opsiyonel) URL uretimi icin X kullanici adiniz
X_HANDLE=<X_HANDLE>

# Groq LLM (caption uretimi)
GROQ_API_KEY=<GROQ_API_KEY>
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL=llama-3.3-70b-versatile

# Notion
NOTION_SOCIAL_TOKEN=<NOTION_TOKEN>
NOTION_DB_REELS_KAPAK=<NOTION_DB_ID>
NOTION_TWITTER_DB_ID=<NOTION_DB_ID>

# Google Service Account JSON (base64 encoded) — Drive erisimi icin
GOOGLE_SERVICE_ACCOUNT_JSON=<GOOGLE_SERVICE_ACCOUNT_JSON_BASE64>

# (Opsiyonel) Video secim onceligi — virgullu liste
VIDEO_PATTERN_PRIORITY=tiktok,insta

# (Opsiyonel) Video boyut limitleri (byte)
MAX_VIDEO_BYTES=524288000
REENCODE_OVER_BYTES=209715200
