# Web_Site_Satis_Otomasyonu — Environment Variables
# Bu dosyayi `.env` olarak kopyalayip kendi degerlerinizi girin.

# ── Apify (Google Maps scraping, fail-over destekli) ────────────────────
APIFY_API_KEY_1=<APIFY_API_KEY>
APIFY_API_KEY_2=<APIFY_API_KEY>

# ── Notion (Lead Onay DB) ───────────────────────────────────────────────
NOTION_API_TOKEN=<NOTION_TOKEN>
# Kendi Notion workspace'inizde bir kokpit sayfasi olusturun, ID'sini girin.
NOTION_COCKPIT_PAGE_ID=<NOTION_PAGE_ID>
# Ilk calistirmada DB olusturulup ID buraya yazilir.
NOTION_LEAD_DB_ID=<NOTION_DB_ID>

# ── Supabase (opsiyonel ANA logger; yoksa disabled) ─────────────────────
SUPABASE_URL=<SUPABASE_URL>
SUPABASE_ANON_KEY=<SUPABASE_KEY>
