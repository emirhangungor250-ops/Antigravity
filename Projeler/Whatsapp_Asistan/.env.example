PORT=3456

# --- ManyChat ---
# ManyChat API token (https://manychat.partnerlinks.io/9vfoe2mjua3j-ogcg6e -> Settings -> API)
MANYCHAT_API_TOKEN=<MANYCHAT_API_TOKEN>
# Bota cevap yazilan custom field ID'si
MANYCHAT_FIELD_ID=<MANYCHAT_FIELD_ID>
# KVKK akisinda tetiklenecek flow ID'si
MANYCHAT_FLOW_ID=<MANYCHAT_FLOW_ID>

# --- LLM ---
OPENAI_API_KEY=<OPENAI_API_KEY>
GROQ_API_KEY=<GROQ_API_KEY>

# --- Supabase (hafiza + bilgi tabani embedding) ---
SUPABASE_URL=<SUPABASE_URL>
SUPABASE_SERVICE_ROLE_KEY=<SUPABASE_KEY>

# --- E-posta (eskalasyon bildirimleri) ---
RESEND_API_KEY=<RESEND_API_KEY>
# Eskalasyon mesajlarinin gidecegi adres
ESCALATION_EMAIL=escalation@example.com
# Eskalasyon maili fail olursa bildirim gidecek admin adresi
ADMIN_NOTIFY_EMAIL=admin@example.com

# --- Guvenlik ---
# ManyChat External Request custom header'inda gonderilecek shared secret
WHATSAPP_WEBHOOK_SECRET=
# Admin endpoint'leri (x-admin-key header) icin shared secret.
# Bos birakilirsa admin endpoint'leri tamamen kapalidir.
ADMIN_SECRET=

# KVKK aydinlatma metninizin yayinda oldugu URL
KVKK_URL=https://example.com/kvkk

# --- Davranis (opsiyonel — degerler default'lu) ---
# production disindaki degerlerde debug log acilir
NODE_ENV=development
# true ise dis servislere (mail, ManyChat) gercek istek atilmaz — test icin
SIMULATION_MODE=false
# Ardisik mesajlari birlestirme bekleme sureleri (ms)
COALESCE_INITIAL_MS=3000
COALESCE_STRAGGLER_MS=1500
