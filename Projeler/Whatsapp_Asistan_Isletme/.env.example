# ============================================================================
# İşletme WhatsApp Asistan — Ortam Degiskenleri
# ============================================================================
# Bu dosyayi `.env` olarak kopyalayin, kendi anahtarlarinizi yazin.
# .env dosyasi gizlidir, repo'ya commit edilmez.

# --- Sunucu ---
PORT=3456

# --- İşletme kimliği (prompt + mesaj + mail basliklarinda kullanilir) ---
BUSINESS_NAME=<ISLETME_ADI>
BUSINESS_SECTOR=<sektör/hizmet açıklaması>

# --- ManyChat (WhatsApp <-> Bot kopru) ---
# ManyChat: WhatsApp mesajlarini webhook ile bota yollar, asistanin cevabini WhatsApp'a iletir.
# https://manychat.partnerlinks.io/9vfoe2mjua3j-ogcg6e -> Settings -> API -> kendi token'iniz
MANYCHAT_API_TOKEN=
# Custom field ID (asistanin cevabini koyacagi alan)
MANYCHAT_FIELD_ID=
# Flow ID (cevap geldiginde tetiklenecek flow)
MANYCHAT_FLOW_ID=

# --- OpenAI (ana LLM ve embedding) ---
# https://platform.openai.com/api-keys
OPENAI_API_KEY=

# --- Groq (KVKK intent + ses transkripsiyon) ---
# https://console.groq.com/keys
GROQ_API_KEY=

# --- Supabase (veritabani + KB embedding) ---
# https://supabase.com -> Project Settings -> API
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# --- Resend (eskalasyon e-postasi) ---
# https://resend.com -> API Keys
RESEND_API_KEY=
# Hangi adresten gonderilecek (Resend'de dogrulanmis domain olmali)
RESEND_FROM_EMAIL=asistan@<ISLETME_WEBSITE>

# Eskalasyon hangi e-postaya gidecek (satis/destek ekibi)
ESCALATION_EMAIL=<EMAIL>
# Mail gonderimi fail olursa kim haberdar olacak
ADMIN_NOTIFY_EMAIL=<ADMIN_EMAIL>

# --- Guvenlik ---
# ManyChat webhook'unun custom header'inda gonderecegi paylasilan sifre
# Uretmek icin: openssl rand -hex 32
WHATSAPP_WEBHOOK_SECRET=
# Admin endpoint'leri (/admin/kb-status vs.) icin ayri sifre
ADMIN_SECRET=

# --- Marka mesaji (opsiyonel override) ---
KVKK_URL=https://<ISLETME_WEBSITE>/kvkk
# KVKK_MESSAGE=  # bos birakirsaniz varsayilan kullanilir
# WELCOME_MESSAGE=  # bos birakirsaniz varsayilan kullanilir

# --- KB versiyon (seed scripti hangi dosyayi okuyacak) ---
KB_FILENAME=bilgi-tabani-v1.md
KB_VERSION=v1

# --- Burst coalesce (musteri arka arkaya mesaj attiginda) ---
COALESCE_INITIAL_MS=3000
COALESCE_STRAGGLER_MS=1500
