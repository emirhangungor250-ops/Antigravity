# YT_Otomasyonu — Ortam Degiskenleri
# Bu dosyayi .env olarak kopyalayin ve kendi degerlerinizi girin.

# Ortam: development (DRY-RUN) veya production
ENV=development

# ── AI Servisleri ──
OPENAI_API_KEY=<OPENAI_API_KEY>
KIE_API_KEY=<KIE_API_KEY>
KIE_BASE_URL=https://api.kie.ai/api/v1

# ── Video Birlestirme (Replicate) ──
REPLICATE_API_TOKEN=<REPLICATE_API_TOKEN>
# (Opsiyonel) Replicate merge modeli surum hash'i
REPLICATE_MERGE_VERSION=

# ── YouTube OAuth2 ──
# Google Cloud Console'dan OAuth client olusturup buraya girin.
YOUTUBE_CLIENT_ID=<GOOGLE_CLIENT_ID>
YOUTUBE_CLIENT_SECRET=<GOOGLE_CLIENT_SECRET>
# setup_youtube.py calistirildiktan sonra uretilir.
YOUTUBE_REFRESH_TOKEN=<YOUTUBE_REFRESH_TOKEN>
YOUTUBE_CATEGORY_ID=15
YOUTUBE_PRIVACY=public
YOUTUBE_ENABLED=true

# ── Notion (opsiyonel — log takibi) ──
NOTION_SOCIAL_TOKEN=<NOTION_TOKEN>
NOTION_DB_YOUTUBE_OTOMASYON=<NOTION_DB_ID>

# ── Polling Ayarlari (opsiyonel) ──
POLL_INITIAL_WAIT=60
POLL_INTERVAL=15
POLL_MAX_ATTEMPTS=40

# ── Cikti cozunurlugu (opsiyonel) ──
DEFAULT_RESOLUTION=720p
