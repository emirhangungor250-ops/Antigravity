# ============================================================================
# YouTube Yorum Otomasyonu — Ortam Değişkenleri
# ============================================================================
# Bu dosyayı `.env` olarak kopyala, kendi anahtarlarınla doldur.
# .env gizlidir, repo'ya commit edilmez.

# ── Kanal (ZORUNLU) ──────────────────────────────────────
# Hangi YouTube kanalının yorumları taranacak. Kanal ID'si UC... ile başlar.
# https://www.youtube.com/account_advanced üzerinden veya kanal URL'inden bul.
YOUTUBE_CHANNEL_ID=<YOUTUBE_CHANNEL_ID>
# Loglarda/mailde görünen kanal adı (kozmetik, opsiyonel).
YOUTUBE_CHANNEL_TITLE=

# ── Creator kimliği (AI'nın taklit edeceği ses) ──────────
# AI yorumları kimin adına sınıflar ve kimin sesinde cevap yazar.
YT_CREATOR_NAME=<KANAL_SAHIBI_ADI>
# Tek satır tanım, ör. "yemek tarifi paylaşan bir YouTuber".
YT_CREATOR_BIO=<kanalın konusu / tek satır tanım>

# ── YouTube (Faz 1: sadece API key gerekir) ──────────────
# YouTube Data API v3 anahtarı (okuma). https://console.cloud.google.com
YOUTUBE_API_KEY=<YOUTUBE_API_KEY>

# ── YouTube OAuth (Faz 2: yorum yazma — youtube.force-ssl) ─
# Google Cloud Console -> OAuth 2.0 Client ID (Desktop app).
YOUTUBE_CLIENT_ID=<YOUTUBE_CLIENT_ID>
YOUTUBE_CLIENT_SECRET=<YOUTUBE_CLIENT_SECRET>
# Production'da token JSON string olarak (setup_youtube_forcessl.py çıktısı):
YOUTUBE_FORCESSL_TOKEN_JSON=

# ── Supabase (corpus + durum) ────────────────────────────
# https://supabase.com -> Project Settings -> API
SUPABASE_URL=<SUPABASE_URL>
SUPABASE_SERVICE_ROLE_KEY=<SUPABASE_KEY>

# ── Embedding (Voyage voyage-3 / 1024d) ──────────────────
# https://www.voyageai.com -> API Keys
VOYAGE_API_KEY=<VOYAGE_API_KEY>
# YT_EMBEDDING_MODEL=voyage-3   # değiştirmek istersen (vektör boyutu 1024 kalmalı)

# ── LLM (varsayılan: gpt-4.1-mini @ OpenAI direkt) ────────
# https://platform.openai.com/api-keys
OPENAI_API_KEY=<OPENAI_API_KEY>
# Opsiyonel: ayrı bir "data-shared" anahtarın varsa öncelikli okunur.
OPENAI_API_KEY_DATA_SHARED=
# Opsiyonel: model adında "/" varsa OpenRouter'a yönlenir (ör. anthropic/...)
OPENROUTER_API_KEY=<OPENROUTER_API_KEY>
# YT_WORTH_MODEL=gpt-4.1-mini   # yorum sınıflama modeli
# YT_REPLY_MODEL=gpt-4.1-mini   # Faz 2 cevap üretim modeli

# ── Mail raporu (Resend + kendi doğrulanmış domain'in) ───
# https://resend.com -> API Keys ; domain'ini DKIM/SPF/DMARC ile doğrula
RESEND_API_KEY=<RESEND_API_KEY>
YT_REPORT_TO=<EMAIL>                           # raporu kim alacak
YT_REPORT_FROM=Asistan <asistan@<WEBSITE>>     # gönderen (doğrulanmış domain'inde)
YT_REPORT_REPLY_TO=<EMAIL>

# ── Faz 2 onay/yanıt web servisi ─────────────────────────
YT_APPROVAL_BASE_URL=            # web servisinin adresi (Faz 2 onay akışını deploy edersen)
YT_APPROVAL_SECRET=              # HMAC imza sırrı (üret: openssl rand -hex 32)

# ── Kopyala sayfası (eşlik eden YouTube_Kopya_Sayfa servisi) ─
YT_COPY_PAGE_URL=                # o servisin adresi (boşsa kart YouTube derin linkine düşer)

# ── Davranış anahtarları ─────────────────────────────────
YT_PHASE=1                       # 1=rapor+öğren, 2=AI cevapla
YT_AUTO_POST=0                   # Faz 2 gölge dönem freni; güven oturunca 1
YT_DRY_RUN=0                     # 1=mail/yazma yapma, sadece logla
YT_LOOKBACK_DAYS=7               # yeni yorum penceresi (tekrarı DB önler)
YT_CORPUS_READY=50               # bu kadar cevap öğrenince "Faz 2'ye hazırım" sinyali
# YT_REPORT_MIN_SCORE=55         # maile girme eşiği (0-100)
# YT_MAX_THREADS=50              # tek koşuda taranacak max yorum thread (opsiyonel, varsayılan var)
# YT_MAX_EMAIL_CARDS=15          # rapor mailindeki max yorum kartı (opsiyonel, varsayılan var)
