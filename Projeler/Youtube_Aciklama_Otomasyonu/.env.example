# ── Notion ──────────────────────────────────────────────────────────────
NOTION_SOCIAL_TOKEN=<NOTION_TOKEN>
# Videoların listelendiği Notion DB ID'si (Reels + YouTube aynı DB ise
# YouTube ayrımı page icon ile yapılır: icon.custom_emoji.name == 'youtube_logo')
NOTION_DB_YOUTUBE_ISBIRLIKLERI=<NOTION_DB_ID>

# ── Anthropic (Claude Opus 4.7) ─────────────────────────────────────────
ANTHROPIC_API_KEY=<ANTHROPIC_API_KEY>

# ── Kanal kimliği + içerik tonu ─────────────────────────────────────────
# Kendi YouTube kanalınızın UC ile başlayan ID'si (style corpus için)
YOUTUBE_CHANNEL_ID=<YOUTUBE_CHANNEL_ID>
# YouTube API key (transcript dışı meta fallback, opsiyonel)
YOUTUBE_API_KEY=
# Açıklama prompt'unda kullanılacak kanal sahibi adı
CREATOR_NAME=<KULLANICI_ADI>
# Organic (iş birliği olmayan) videolarda hero'ya eklenecek sabit CTA link bloğu.
# Kendi topluluk / hizmet / sosyal linklerinizi buraya yazın. Çok satırlı olabilir.
ORGANIC_CTA_BLOCK=
# build_style_corpus.py affiliate link tespiti için kendi promo kodunuz/handle'ınız
AFFILIATE_HINT_KEYWORD=

# ── Apify (style corpus için bir kerelik scrape) ────────────────────────
APIFY_API_KEY_1=<APIFY_API_KEY>

# ── Google Drive (Docs üretmek için OAuth) ──────────────────────────────
# Lokal'de _knowledge/credentials/oauth/gmail-outreach-token.json yeterli
# Railway'de token JSON'unu buraya koy:
GOOGLE_OUTREACH_TOKEN_JSON=

# ── Telegram (başarı/hata bildirimi) ────────────────────────────────────
TELEGRAM_BOT_TOKEN=<TELEGRAM_BOT_TOKEN>
TELEGRAM_ADMIN_CHAT_ID=<TELEGRAM_CHAT_ID>
