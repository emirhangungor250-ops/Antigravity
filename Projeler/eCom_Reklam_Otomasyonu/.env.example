# eCom Reklam Otomasyonu — Gerekli Ortam Degiskenleri
# Bu dosyayi .env olarak kopyalayin ve kendi degerlerinizi girin.

ENV=production

# Telegram
TELEGRAM_ECOM_BOT_TOKEN=<TELEGRAM_BOT_TOKEN>
TELEGRAM_ADMIN_CHAT_ID=<TELEGRAM_CHAT_ID>

# OpenAI (GPT-4.1 Mini)
OPENAI_API_KEY=<OPENAI_API_KEY>
OPENAI_MODEL=gpt-4.1-mini

# Perplexity (Marka Arastirmasi)
PERPLEXITY_API_KEY=<PERPLEXITY_API_KEY>
PERPLEXITY_BASE_URL=https://api.perplexity.ai

# ImgBB (Gorsel Hosting)
IMGBB_API_KEY=<IMGBB_API_KEY>

# Kie AI (Seedance 2.0 + Nano Banana 2)
KIE_API_KEY=<KIE_API_KEY>
KIE_BASE_URL=https://api.kie.ai/api/v1/

# ElevenLabs (Turkce TTS)
ELEVENLABS_API_KEY=<ELEVENLABS_API_KEY>
ELEVENLABS_MODEL=eleven_v3

# Replicate (Video + Ses Birlestirme)
REPLICATE_API_TOKEN=<REPLICATE_API_TOKEN>

# Notion (Uretim Loglari)
NOTION_SOCIAL_TOKEN=<NOTION_TOKEN>
NOTION_DB_ECOM_REKLAM=<NOTION_DB_ID>
# (Opsiyonel) Chat hafiza DB'si
NOTION_CHAT_DB_ID=<NOTION_DB_ID>

# Upload-Post (Sosyal Medya Paylasimi — TikTok/YouTube/Instagram/...)
UPLOAD_POST_API_KEY=<UPLOAD_POST_API_KEY>
UPLOAD_POST_PROFILE=<UPLOAD_POST_PROFILE>

# Firecrawl (Web Scraping — urun sayfasi icerik cikarimi)
FIRECRAWL_API_KEY=<FIRECRAWL_API_KEY>
